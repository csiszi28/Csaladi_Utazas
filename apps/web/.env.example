NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL – KÖTELEZŐ a regisztrációhoz és minden adatművelethez!
# Supabase Dashboard → Project Settings → Database → Connection string
# 1) "Transaction pooler" (port 6543) → DATABASE_URL
# 2) "Session pooler" vagy "Direct" (port 5432) → DIRECT_URL

DATABASE_URL=postgresql://postgres.xxx:[JELSZO]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:[JELSZO]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
